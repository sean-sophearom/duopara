generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  vocabulary    VocabularyWord[]
  generatedTexts GeneratedText[]
  readingSessions ReadingSession[]
  settings      UserSettings?
}

model UserSettings {
  id                 String @id @default(uuid())
  userId             String @unique
  user               User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetLanguage     String @default("Spanish")
  nativeLanguage     String @default("English")
  knownWordsRatio    Int    @default(80)  // Percentage 0-100
  defaultDifficulty  String @default("intermediate") // beginner, intermediate, advanced
}

model VocabularyWord {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  word          String
  language      String
  translation   String?
  partOfSpeech  String?  // noun, verb, adjective, etc.
  baseForm      String?  // infinitive/singular form
  
  status        String   @default("learning") // learning, learned, mastered
  timesEncountered Int   @default(0)
  timesCorrect  Int      @default(0)
  
  // Spaced repetition fields
  lastPracticedAt  DateTime?
  practiceStreak   Int      @default(0)  // Consecutive correct answers
  nextPracticeAt   DateTime?             // Scheduled next practice (spaced repetition)
  difficultyScore  Float    @default(2.5) // SM-2 easiness factor (1.3-5.0)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  masteredAt    DateTime?

  @@unique([userId, word, language])
  @@index([userId, language, status])
  @@index([userId, nextPracticeAt])
}

model GeneratedText {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  topic           String
  language        String
  difficulty      String   // beginner, intermediate, advanced
  knownWordsRatio Int      // The ratio used to generate
  
  title           String
  content         String   // The generated text
  wordCount       Int
  
  // Words analysis
  knownWordsUsed    String // JSON array of known words used
  newWordsIntroduced String // JSON array of new words introduced
  
  // Cached parallel translation: JSON { targetLanguage, sentences: [{translation, literalTranslation}] }
  parallelTranslation String?

  createdAt       DateTime @default(now())
  
  readingSessions ReadingSession[]

  @@index([userId, createdAt])
}

model ReadingSession {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  textId          String
  text            GeneratedText @relation(fields: [textId], references: [id], onDelete: Cascade)
  
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  
  // Tracking
  wordsLookedUp   String   @default("[]") // JSON array of words translated
  wordsMarkedLearned String @default("[]") // JSON array of words marked as learned
  
  @@index([userId, startedAt])
}

model TranslationCache {
  id         String   @id @default(uuid())
  endpoint   String   // 'sentence' | 'full'
  cacheKey   String   // SHA-256 hash of all input fields
  response   String   // JSON-encoded response
  createdAt  DateTime @default(now())

  @@unique([endpoint, cacheKey])
  @@index([endpoint, cacheKey])
}

// For tracking daily activity streaks
model DailyActivity {
  id        String   @id @default(uuid())
  userId    String
  date      DateTime
  
  textsRead Int      @default(0)
  wordsLearned Int   @default(0)
  minutesActive Int  @default(0)
  
  @@unique([userId, date])
  @@index([userId, date])
}

// ============================================
// Practice / Vocabulary Games
// ============================================

// Cached LLM-generated game data for words (shared across users by language pair)
model GameWordData {
  id              String   @id @default(uuid())
  word            String   // The source word
  sourceLanguage  String   // Language of the word
  targetLanguage  String   // Language for translations
  
  // LLM-generated data (JSON)
  definition              String   // Definition in target language
  translation             String   // The correct translation in target language
  distractorDefinitions   String   // JSON array of 5 wrong definitions
  distractorTranslations  String   // JSON array of 5 wrong translations
  exampleSentences        String   // JSON array of sentences with blanks [{sentence, blankWord, fullSentence}]
  falseTranslation        String   // A plausible but wrong translation for true/false game
  
  createdAt       DateTime @default(now())
  
  @@unique([word, sourceLanguage, targetLanguage])
  @@index([word, sourceLanguage, targetLanguage])
}

// A practice session (one game playthrough)
model PracticeSession {
  id              String   @id @default(uuid())
  userId          String
  
  gameType        String   // definition, translation, reverse, fillblank, matching, truefalse
  sourceLanguage  String
  targetLanguage  String
  
  totalWords      Int
  correctCount    Int      @default(0)
  incorrectCount  Int      @default(0)
  
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  
  // Session configuration (JSON)
  config          String   @default("{}") // {optionCount, wordCount, statusFilter, etc.}
  
  attempts        PracticeAttempt[]
  
  @@index([userId, startedAt])
  @@index([userId, gameType])
}

// Individual word attempt within a session
model PracticeAttempt {
  id              String   @id @default(uuid())
  sessionId       String
  session         PracticeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  vocabularyWordId String  // Reference to the vocabulary word
  
  isCorrect       Boolean
  responseTimeMs  Int?     // How long the user took to answer
  
  // What was shown and selected (for analytics)
  questionData    String   // JSON - what was displayed
  userAnswer      String   // What the user selected/typed
  correctAnswer   String   // The correct answer
  
  attemptedAt     DateTime @default(now())
  
  @@index([sessionId])
  @@index([vocabularyWordId])
}
