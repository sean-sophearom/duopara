DATABASE_URL="file:./dev.db"
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
PORT=3001

# LLM Provider API Keys (set the ones you want to use)
# Mastra reads these automatically based on your model configuration
OPENAI_API_KEY="your-openai-api-key"
# ANTHROPIC_API_KEY="your-anthropic-api-key"
# GOOGLE_API_KEY="your-google-api-key"
# OPENROUTER_API_KEY="your-openrouter-api-key"

# Optional: Override default models per task
# Format is "provider/model-name" (e.g., "openai/gpt-4o", "anthropic/claude-sonnet-4-20250514")
# LLM_MODEL_GENERATION="openai/gpt-4o"
# LLM_MODEL_TRANSLATION="openai/gpt-4o-mini"
# LLM_MODEL_ANALYSIS="openai/gpt-4o-mini"
