# ── Database ────────────────────────────────────────────────────────────────
# Supported providers: sqlite | mysql | postgresql
DATABASE_PROVIDER="sqlite"

# SQLite (default, file-based – good for development)
DATABASE_URL="file:./dev.db"

# MySQL example:
# DATABASE_PROVIDER="mysql"
# DATABASE_URL="mysql://duopara:password@localhost:3306/duopara"

# PostgreSQL example:
# DATABASE_PROVIDER="postgresql"
# DATABASE_URL="postgresql://duopara:password@localhost:5432/duopara"

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3009
FRONTEND_URL="http://localhost:5173"

JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# LLM Provider API Keys (set the ones you want to use)
# Mastra reads these automatically based on your model configuration
OPENAI_API_KEY="your-openai-api-key"
# ANTHROPIC_API_KEY="your-anthropic-api-key"
# GOOGLE_API_KEY="your-google-api-key"
# OPENROUTER_API_KEY="your-openrouter-api-key"

# Optional: Override default models per task
# Format is "provider/model-name" (e.g., "openai/gpt-4o", "anthropic/claude-sonnet-4-20250514")
# LLM_MODEL_GENERATION="openai/gpt-4o"
# LLM_MODEL_TRANSLATION="openai/gpt-4o-mini"
# LLM_MODEL_ANALYSIS="openai/gpt-4o-mini"

# ── Environment ──────────────────────────────────────────────────────────────
NODE_ENV="development"

DATABASE_URL="file:./dev.db"
JWT_SECRET="change-this-to-a-secure-random-string-in-production"
OPENAI_API_KEY="your-openai-api-key-here"
PORT=3009
FRONTEND_URL="http://localhost:5173"

# Switch models per task via environment variables
LLM_MODEL_GENERATION="google/gemini-3-flash-preview"           # or "anthropic/claude-opus-4-1"
LLM_MODEL_TRANSLATION="google/gemini-2.5-flash-lite"     # or "google/gemini-2.5-flash-lite"
LLM_MODEL_ANALYSIS="google/gemini-2.5-flash-lite"
GOOGLE_GENERATIVE_AI_API_KEY=