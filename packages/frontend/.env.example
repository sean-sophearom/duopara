# ── Dev server ───────────────────────────────────────────────────────────────
# Port the Vite dev server listens on
VITE_PORT=5173

# Backend URL used by the Vite proxy (dev only).
# In production nginx forwards /api → backend directly.
VITE_API_URL=http://localhost:3009

# Sub-path when the app is served under a directory (no trailing slash).
# Leave as "/" for root deployment, or set to e.g. "/duopara" for sub-path.
VITE_BASE_PATH="/"