{
  "name": "duopara",
  "version": "1.0.0",
  "description": "Dynamic reading platform for language learning",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "nx run-many -t dev --projects=@duopara/backend,@duopara/frontend --output-style=stream",
    "dev:backend": "nx run @duopara/backend:dev",
    "dev:frontend": "nx run @duopara/frontend:dev",
    "build": "nx run-many -t build --projects=@duopara/backend,@duopara/frontend",
    "build:shared": "nx run @duopara/shared:build",
    "db:push": "npm run db:push --workspace=@duopara/backend",
    "db:generate": "npm run db:generate --workspace=@duopara/backend",
    "db:studio": "npm run db:studio --workspace=@duopara/backend"
  },
  "devDependencies": {
    "nx": "22.5.4"
  }
}